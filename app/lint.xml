        <ignore path="src/main/res/mipmap-anydpi-v26/ic_launcher_round.xml" />
        <ignore path="src/main/res/drawable/ic_mono.xml" />
        <ignore path="src/main/res/values/colors.xml" />
        <ignore path="src/main/res/layout/item_lyrics_item.xml" />
