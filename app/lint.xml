    <issue id="StringFormatMatches">
        <ignore path="src/main/java/dev/brahmkshatriya/echo/ui/playlist/edit/EditPlaylistBottomSheet.kt" />
        <ignore path="src/main/java/dev/brahmkshatriya/echo/ui/extensions/ExtensionInfoFragment.kt" />
