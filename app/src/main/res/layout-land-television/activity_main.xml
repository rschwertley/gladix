<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/hiddenWebViewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:nextFocusDown="@id/tvMiniPlayer"
        tools:layout="@layout/fragment_home"
        tools:layout_marginStart="64dp" />

    <!-- Left navigation panel: rail + Now Playing footer -->
    <LinearLayout
        android:id="@+id/navRailContainer"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical">

        <com.google.android.material.navigationrail.NavigationRailView
            android:id="@+id/navView"
            style="@style/NavView"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minWidth="@dimen/nav_width"
            android:nextFocusDown="@id/nowPlayingRail"
            app:elevation="0dp"
            app:itemMinHeight="64dp"
            app:menu="@menu/nav_menu"
            app:menuGravity="center" />

        <View
            android:id="@+id/nowPlayingDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutlineVariant"
            android:visibility="gone" />

        <!-- Now Playing footer — TV only, shown when a track is loaded -->
        <LinearLayout
            android:id="@+id/nowPlayingRail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true"
            android:background="?attr/selectableItemBackground"
            android:visibility="gone"
            android:nextFocusRight="@id/navHostFragment">

            <ImageView
                android:id="@+id/nowPlayingThumb"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music"
                android:importantForAccessibility="no" />

        </LinearLayout>

    </LinearLayout>

    <!-- Mini-player bar: shown when a track is loaded but full-screen player is hidden -->
    <include
        layout="@layout/fragment_player_mini_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/nav_width" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/playerFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:outlineProvider="none"
        app:behavior_hideable="true"
        app:behavior_peekHeight="@dimen/bottom_player_peek_height"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        tools:layout="@layout/fragment_player_tv" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
